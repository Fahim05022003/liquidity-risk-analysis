# OpenAI API Key (required for AI analysis)
# Generate from: https://platform.openai.com/account/api-keys
# Must start with sk-
OPENAI_API_KEY=sk-your-api-key-here

# Neon PostgreSQL Database URL (required)
# Format: postgresql://user:password@host/database
# Provided by Neon integration when connected
DATABASE_URL=postgresql://user:password@db.neon.tech/neon

# Better Auth Secret (required for session management)
# Generate with: openssl rand -base64 32
# Must be at least 32 characters
BETTER_AUTH_SECRET=your-random-secret-here-at-least-32-chars

# Optional: Custom Better Auth URL
# Only set if using a custom domain; defaults to deployment URL
# BETTER_AUTH_URL=https://yourdomain.com
